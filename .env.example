# ── Google 管理員登入 ──────────────────────────────────────────────────────────
# 可進入後台的 Google 帳號 Email（逗號分隔，例如：ciut0000@gmail.com,other@gmail.com）
# 伺服器端驗證，不要放在 NEXT_PUBLIC_ 前綴，除非你也需要前端顯示管理後台連結
ADMIN_GOOGLE_EMAILS=ciut0000@gmail.com

# 前台 UI 判斷用（控制「管理後台」按鈕是否顯示）
# 值與 ADMIN_GOOGLE_EMAILS 相同即可
NEXT_PUBLIC_ADMIN_GOOGLE_EMAILS=ciut0000@gmail.com

# ── Email 寄送（Resend）────────────────────────────────────────────────────────
# 使用 Resend 寄送完整塔羅結果 Email
# 申請帳號：https://resend.com
# 若未設定，Email 寄送功能會顯示「服務尚未啟用」，不會影響其他功能。
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 寄件人格式："顯示名稱 <email@yourdomain.com>"
# 必須使用已在 Resend 驗證的網域
EMAIL_FROM=宇宙偷偷話 <noreply@yourdomain.com>
